<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Marcel Chanard — Portfolio</title>
  <style>
    :root {
      --bg:            #04070c;
      --text:          #eef2f8;
      --muted:         #7a96b4;
      --soft:          #3d5873;
      --line:          rgba(255,255,255,0.07);
      --line-hover:    rgba(255,255,255,0.13);
      --accent:        #4a90e2;
      --accent-dim:    rgba(74,144,226,0.10);
      --accent-border: rgba(74,144,226,0.25);
      --max:           1060px;
    }
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', Helvetica, Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }

    /* ── Topbar ──────────────────────────────────────────── */
    .topbar {
      position: sticky; top: 0; z-index: 100;
      width: 100%;
      border-bottom: 1px solid var(--line);
      background: rgba(4,7,12,0.82);
      backdrop-filter: saturate(180%) blur(20px);
      -webkit-backdrop-filter: saturate(180%) blur(20px);
    }
    .topbar-inner {
      max-width: var(--max); margin: 0 auto;
      padding: 0 28px;
      height: 56px;
      display: flex; justify-content: space-between; align-items: center;
    }
    .brand { font-size: 16px; font-weight: 600; letter-spacing: -0.01em; }
    .nav { display: flex; gap: 28px; align-items: center; }
    .nav a { font-size: 14px; color: var(--muted); transition: color .15s; letter-spacing: -0.01em; }
    .nav a:hover, .nav a.active { color: var(--text); }

    /* ── Language toggle ─────────────────────────────────── */
    .lang-toggle {
      display: flex; gap: 1px;
      margin-left: 12px;
    }
    .lang-btn {
      background: none; border: none; cursor: pointer;
      padding: 4px 9px; border-radius: 6px;
      font-size: 12px; font-weight: 700; letter-spacing: .04em;
      color: var(--soft);
      transition: all .15s;
    }
    .lang-btn.active { background: var(--accent-dim); color: var(--accent); }
    .lang-btn:hover:not(.active) { color: var(--muted); }

    /* ── Back to top ─────────────────────────────────────── */
    .back-to-top {
      position: fixed; right: 28px; bottom: 32px; z-index: 50;
      width: 40px; height: 40px; border-radius: 50%;
      background: rgba(10,18,30,0.88);
      border: 1px solid var(--line);
      color: var(--muted); font-size: 17px;
      display: flex; align-items: center; justify-content: center;
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      transition: opacity .25s, transform .2s, border-color .2s, color .2s;
      opacity: 0; pointer-events: none;
    }
    .back-to-top.visible { opacity: 1; pointer-events: auto; }
    .back-to-top:hover { border-color: var(--accent-border); color: var(--accent); transform: translateY(-3px); }

    /* ── Hero ─────────────────────────────────────────────── */
    .hero {
      min-height: calc(100vh - 56px);
      display: flex; align-items: center; justify-content: center;
      padding: 80px 28px 80px;
      text-align: center;
    }
    .hero-inner { max-width: var(--max); width: 100%; }
    .hero-eyebrow {
      display: inline-block;
      font-size: 11px; font-weight: 700; letter-spacing: .16em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 22px;
    }
    h1 {
      font-size: clamp(48px, 7vw, 88px);
      line-height: 1.01; margin: 0; font-weight: 800; letter-spacing: -0.04em;
    }
    .hero-sub {
      font-size: clamp(16px, 2vw, 20px);
      color: var(--muted); margin-top: 18px; line-height: 1.5;
      letter-spacing: -0.01em;
    }
    .hero-divider {
      width: 32px; height: 2px; border-radius: 2px;
      background: var(--accent); margin: 36px auto;
      opacity: 0.7;
    }

    /* Hero grid — clean table lines, no fills */
    .hero-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      border-top: 1px solid var(--line);
      border-left: 1px solid var(--line);
    }
    .hero-box {
      padding: 28px 22px;
      text-align: left;
      border-right: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      transition: background .2s;
    }
    .hero-box:hover { background: rgba(255,255,255,0.022); }
    .hero-box-label {
      font-size: 10px; font-weight: 700; letter-spacing: .13em;
      text-transform: uppercase; color: var(--accent);
      margin-bottom: 8px; opacity: .8;
      transition: opacity .15s;
    }
    .hero-box:hover .hero-box-label { opacity: 1; }
    .hero-box-title { font-size: 16px; font-weight: 700; margin-bottom: 7px; letter-spacing: -0.01em; }
    .hero-box-text { font-size: 13px; line-height: 1.65; color: var(--muted); }

    /* ── Main ───────────────────────────────────────────────── */
    main { padding: 0 28px 120px; }

    /* ── Sections ─────────────────────────────────────────── */
    section {
      padding: 80px 0;
      border-top: 1px solid var(--line);
    }
    .section-inner {
      max-width: 700px; margin: 0 auto;
      text-align: left;
    }
    .section-label {
      font-size: 10px; font-weight: 700; letter-spacing: .16em;
      text-transform: uppercase; color: var(--accent);
      margin-bottom: 12px; opacity: .8;
    }
    h2 {
      font-size: clamp(28px, 3vw, 42px);
      line-height: 1.08; margin: 0 0 36px; font-weight: 800; letter-spacing: -0.03em;
      text-align: left;
    }
    p {
      font-size: clamp(15px, 1.4vw, 16.5px); line-height: 1.85;
      color: var(--muted); margin: 0; letter-spacing: -0.005em;
    }
    .text-block { display: flex; flex-direction: column; gap: 18px; }

    /* ── Skills ──────────────────────────────────────────────── */
    .skills-list { display: flex; flex-direction: column; }
    .skill-row {
      display: flex; align-items: flex-start; gap: 20px;
      padding: 22px 0;
      border-top: 1px solid var(--line);
    }
    .skill-row:first-child { border-top: none; }
    .skill-name-col {
      flex: 0 0 180px;
      display: flex; align-items: center; gap: 9px;
    }
    .skill-icon-emoji { font-size: 18px; line-height: 1; }
    .skill-icon { width: 22px; height: 22px; object-fit: contain; }
    .skill-title { font-size: 14px; font-weight: 700; letter-spacing: -0.01em; }
    .skill-tags-col { flex: 1; display: flex; flex-direction: column; gap: 8px; }
    .skill-tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .tag {
      padding: 3px 10px; border-radius: 999px;
      background: var(--accent-dim); border: 1px solid var(--accent-border);
      color: var(--accent); font-size: 12px; font-weight: 500; white-space: nowrap;
      opacity: .9;
    }
    .tag.neutral {
      background: rgba(255,255,255,0.03); border-color: var(--line);
      color: var(--muted);
    }
    .skill-note {
      font-size: 12.5px; color: var(--soft); line-height: 1.65;
    }

    /* ── Experience ────────────────────────────────────────── */
    .exp-entry { padding-left: 16px; border-left: 2px solid var(--accent); }
    .exp-company { font-size: 15px; font-weight: 700; margin-bottom: 3px; letter-spacing: -0.01em; }
    .exp-meta { font-size: 12px; color: var(--soft); margin-bottom: 14px; letter-spacing: .02em; }
    .exp-list {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 8px;
    }
    .exp-list li {
      font-size: 14.5px; line-height: 1.7; color: var(--muted);
      padding-left: 16px; position: relative;
    }
    .exp-list li::before { content: '–'; position: absolute; left: 0; color: var(--accent); opacity: .6; }

    /* ── Contact ───────────────────────────────────────────── */
    .contact-list {
      display: flex; flex-wrap: wrap; column-gap: 40px; row-gap: 14px;
    }
    .contact-item {
      display: flex; align-items: center; gap: 9px;
      font-size: 14px; color: var(--muted);
      padding-bottom: 2px;
      border-bottom: 1px solid transparent;
      transition: color .15s, border-color .15s;
    }
    .contact-item:hover { color: var(--text); border-bottom-color: var(--accent); }
    .contact-icon { font-size: 15px; }

    /* ── Media ─────────────────────────────────────────────── */
    @media (max-width: 760px) {
      .hero-grid { grid-template-columns: 1fr 1fr; }
      .skill-row { flex-direction: column; gap: 10px; }
      .skill-name-col { flex: none; }
      .contact-list { flex-direction: column; gap: 12px; }
      .topbar-inner { padding: 0 18px; }
      main { padding: 0 18px 100px; }
      .hero { padding: 60px 18px; }
    }
    @media (max-width: 480px) {
      .hero-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
